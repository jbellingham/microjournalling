<div class="auth-container">
  <div class="auth-header">
    <h1>Sign In</h1>
    <p>Welcome back! Please sign in to your account.</p>
  </div>

  <div class="auth-form">
    <%= form_with url: login_path, method: :post, local: true, class: "auth-form-content" do |form| %>
      <% if flash[:alert] %>
        <div class="error-messages">
          <div class="alert alert-danger"><%= flash[:alert] %></div>
        </div>
      <% end %>

      <div class="form-group">
        <%= form.label :email, class: "form-label" %>
        <%= form.email_field :email, class: "form-control", placeholder: "Enter your email", required: true %>
      </div>

      <div class="form-group">
        <%= form.label :password, class: "form-label" %>
        <%= form.password_field :password, class: "form-control", placeholder: "Enter your password", required: true %>
      </div>

      <div class="form-actions">
        <%= form.submit "Sign In", class: "btn btn-primary btn-block" %>
      </div>
    <% end %>

    <div class="auth-links">
      <p>Don't have an account? <%= link_to "Sign up here", signup_path, class: "auth-link" %></p>
    </div>
  </div>
</div>
