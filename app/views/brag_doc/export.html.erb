<div class="achievements-header">
  <h1>Export Brag Document</h1>
  <div class="header-actions">
    <div class="user-info">
      <span class="user-name">Welcome, <%= current_user.name %>!</span>
      <%= link_to "Logout", logout_path, class: "btn btn-secondary btn-sm", data: { turbo_method: :delete } %>
    </div>
    <button class="theme-toggle" data-controller="theme" data-action="click->theme#toggle" aria-label="Toggle dark mode">
      <span class="theme-icon theme-icon-light">☀️</span>
      <span class="theme-icon theme-icon-dark">🌙</span>
    </button>
    <%= link_to "Back to Achievements", achievements_path, class: "btn btn-secondary" %>
  </div>
</div>

<nav class="view-tabs">
  <%= link_to "All Achievements", achievements_path, class: "tab-link" %>
  <%= link_to "Weekly View", weekly_achievements_path, class: "tab-link" %>
  <%= link_to "Monthly View", monthly_achievements_path, class: "tab-link" %>
  <%= link_to "Brag Doc Export", brag_doc_export_path, class: "tab-link active" %>
</nav>

<div class="brag-doc-export">
  <div class="export-header">
    <h2>Brag Document Builder</h2>
    <p>Curate your best achievements from your <strong><%= @shortlist_count %> favorites this year</strong> to create the perfect brag document.</p>
  </div>

  <div class="export-stats">
    <div class="stat-card">
      <div class="stat-number"><%= @shortlist_count %></div>
      <div class="stat-label">Shortlist (Favorites)</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-number"><%= @export_count %></div>
      <div class="stat-label">Selected for Export</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-number"><%= @achievements_by_brag_category.count %></div>
      <div class="stat-label">Categories Covered</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-number"><%= @current_year_count %></div>
      <div class="stat-label">This Year Total</div>
    </div>
  </div>

  <!-- Shortlist Selection Interface -->
  <div class="shortlist-section">
    <h3>Select Achievements for Export</h3>
    <p>Choose which of your favorite achievements to include in your final brag document:</p>
    
    <%= form_with url: brag_doc_update_selections_path, method: :patch, local: true, 
        class: "shortlist-form", data: { controller: "brag-selection" } do |form| %>
      
      <div class="shortlist-actions">
        <button type="button" data-action="click->brag-selection#selectAll" class="btn btn-sm btn-secondary">
          Select All
        </button>
        <button type="button" data-action="click->brag-selection#deselectAll" class="btn btn-sm btn-secondary">
          Deselect All
        </button>
        <%= form.submit "Update Selection", class: "btn btn-primary" %>
      </div>
      
      <div class="shortlist-achievements">
        <% @shortlist_achievements.group_by(&:category).each do |category, achievements| %>
          <div class="category-section">
            <h4><%= Achievement::CATEGORIES[category][:name] %> (<%= achievements.count %>)</h4>
            
            <% achievements.each do |achievement| %>
              <div class="shortlist-item">
                <div class="shortlist-checkbox">
                  <%= form.check_box :achievement_ids, 
                      { multiple: true, checked: achievement.include_in_brag_doc, 
                        data: { "brag-selection-target": "checkbox" } }, 
                      achievement.id, "" %>
                </div>
                <div class="shortlist-content">
                  <h5><%= achievement.title %></h5>
                  <p class="shortlist-date"><%= achievement.date.strftime("%B %d, %Y") %></p>
                  <% if achievement.description.present? %>
                    <p class="shortlist-description"><%= truncate(achievement.description, length: 150) %></p>
                  <% end %>
                  <% if achievement.impact_metrics.present? %>
                    <p class="shortlist-impact"><strong>Impact:</strong> <%= truncate(achievement.impact_metrics, length: 100) %></p>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      
      <div class="shortlist-actions bottom-actions">
        <%= form.submit "Update Selection", class: "btn btn-primary btn-large" %>
      </div>
    <% end %>
  </div>

  <!-- Final Export Preview -->
  <% if @export_count > 0 %>
    <div class="final-export-section">
      <div class="final-export-header">
        <h3>Your Final Brag Document Preview</h3>
        <p>This is what will be included in your exported document (<%= @export_count %> achievements selected):</p>
        
        <div class="export-actions">
          <%= link_to "Download as Text", brag_doc_export_path(format: :text), 
              class: "btn btn-primary", 
              download: "brag_doc_#{Date.current.strftime('%Y_%m_%d')}.txt" %>
          <button onclick="window.print()" class="btn btn-secondary">Print Preview</button>
        </div>
      </div>

      <div class="brag-doc-content final-preview">
        <div class="section">
          <h3>Goals for this year:</h3>
          <p class="placeholder-text">- Add your major goals here! Sharing your goals with your manager & coworkers is really nice because it helps them see how they can support you in accomplishing those goals!</p>
        </div>

        <% Achievement.brag_doc_categories.each do |category| %>
          <% achievements_in_category = @achievements_by_brag_category[category] || [] %>
          <% next if achievements_in_category.empty? %>
          
          <div class="section">
            <h3><%= Achievement::CATEGORIES[category][:name] %></h3>
            
            <% achievements_in_category.each do |achievement| %>
              <div class="achievement-entry">
                <h4><%= achievement.title %></h4>
                <div class="achievement-meta">
                  <span class="achievement-date"><%= achievement.date.strftime('%B %d, %Y') %></span>
                  <span class="achievement-category-badge"><%= achievement.display_category %></span>
                </div>
                
                <% if achievement.description.present? %>
                  <div class="achievement-description">
                    <%= simple_format(achievement.description) %>
                  </div>
                <% end %>
                
                <% if achievement.impact_metrics.present? %>
                  <div class="brag-detail">
                    <strong>Impact & Results:</strong>
                    <%= simple_format(achievement.impact_metrics) %>
                  </div>
                <% end %>
                
                <% if achievement.collaboration_details.present? %>
                  <div class="brag-detail">
                    <strong>Collaboration:</strong>
                    <%= simple_format(achievement.collaboration_details) %>
                  </div>
                <% end %>
                
                <% if achievement.learning_outcomes.present? %>
                  <div class="brag-detail">
                    <strong>Learning Outcomes:</strong>
                    <%= simple_format(achievement.learning_outcomes) %>
                  </div>
                <% end %>
                
                <% if achievement.goals_supported.present? %>
                  <div class="brag-detail">
                    <strong>Goals Supported:</strong>
                    <%= simple_format(achievement.goals_supported) %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="empty-export-state">
      <h3>No Achievements Selected</h3>
      <% if @shortlist_count > 0 %>
        <p>Select achievements from your shortlist above to see your brag document preview.</p>
      <% else %>
        <p>You need to mark some achievements as favorites first. Use the ★ button on achievements to add them to your shortlist.</p>
        <div class="empty-state-actions">
          <%= link_to "View All Achievements", achievements_path, class: "btn btn-primary" %>
          <%= link_to "Add New Achievement", new_achievement_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
</div>
