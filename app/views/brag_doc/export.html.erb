<div class="achievements-header">
  <h1>Export Brag Document</h1>
  <div class="header-actions">
    <div class="user-info">
      <span class="user-name">Welcome, <%= current_user.name %>!</span>
      <%= link_to "Logout", logout_path, class: "btn btn-secondary btn-sm", data: { turbo_method: :delete } %>
    </div>
    <button class="theme-toggle" data-controller="theme" data-action="click->theme#toggle" aria-label="Toggle dark mode">
      <span class="theme-icon theme-icon-light">☀️</span>
      <span class="theme-icon theme-icon-dark">🌙</span>
    </button>
    <%= link_to "Back to Achievements", achievements_path, class: "btn btn-secondary" %>
  </div>
</div>

<nav class="view-tabs">
  <%= link_to "All Achievements", achievements_path, class: "tab-link" %>
  <%= link_to "Weekly View", weekly_achievements_path, class: "tab-link" %>
  <%= link_to "Monthly View", monthly_achievements_path, class: "tab-link" %>
  <%= link_to "Brag Doc Export", brag_doc_export_path, class: "tab-link active" %>
</nav>

<div class="brag-doc-export">
  <div class="export-header">
    <h2>Your Brag Document</h2>
    <p>This document shows your <strong>favorite achievements from <%= Date.current.year %></strong> - your curated list for promotion and performance review purposes.</p>
    
    <div class="export-actions">
      <%= link_to "Download as Text", brag_doc_export_path(format: :text), 
          class: "btn btn-primary", 
          download: "brag_doc_#{Date.current.strftime('%Y_%m_%d')}.txt" %>
      <button onclick="window.print()" class="btn btn-secondary">Print</button>
    </div>
  </div>

  <div class="export-stats">
    <div class="stat-card">
      <div class="stat-number"><%= @achievements.count %></div>
      <div class="stat-label">Favorite Achievements</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-number"><%= @achievements_by_brag_category.count %></div>
      <div class="stat-label">Categories Covered</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-number"><%= @total_favorites %></div>
      <div class="stat-label">Total Favorites</div>
    </div>
    
    <div class="stat-card">
      <div class="stat-number"><%= @current_year_count %></div>
      <div class="stat-label">This Year Total</div>
    </div>
  </div>

  <div class="brag-doc-content">
    <div class="section">
      <h3>Goals for this year:</h3>
      <p class="placeholder-text">- Add your major goals here! Sharing your goals with your manager & coworkers is really nice because it helps them see how they can support you in accomplishing those goals!</p>
    </div>

    <% Achievement.brag_doc_categories.each do |category| %>
      <% achievements_in_category = @achievements_by_brag_category[category] || [] %>
      <% next if achievements_in_category.empty? %>
      
      <div class="section">
        <h3><%= Achievement::CATEGORIES[category][:name] %></h3>
        
        <% achievements_in_category.each do |achievement| %>
          <div class="achievement-entry">
            <h4><%= achievement.title %></h4>
            <div class="achievement-meta">
              <span class="achievement-date"><%= achievement.date.strftime('%B %d, %Y') %></span>
              <span class="achievement-category-badge"><%= achievement.display_category %></span>
            </div>
            
            <% if achievement.description.present? %>
              <div class="achievement-description">
                <%= simple_format(achievement.description) %>
              </div>
            <% end %>
            
            <% if achievement.impact_metrics.present? %>
              <div class="brag-detail">
                <strong>Impact & Results:</strong>
                <%= simple_format(achievement.impact_metrics) %>
              </div>
            <% end %>
            
            <% if achievement.collaboration_details.present? %>
              <div class="brag-detail">
                <strong>Collaboration:</strong>
                <%= simple_format(achievement.collaboration_details) %>
              </div>
            <% end %>
            
            <% if achievement.learning_outcomes.present? %>
              <div class="brag-detail">
                <strong>Learning Outcomes:</strong>
                <%= simple_format(achievement.learning_outcomes) %>
              </div>
            <% end %>
            
            <% if achievement.goals_supported.present? %>
              <div class="brag-detail">
                <strong>Goals Supported:</strong>
                <%= simple_format(achievement.goals_supported) %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @achievements_by_brag_category.empty? %>
      <div class="empty-state">
        <h3>No favorite achievements from <%= Date.current.year %> yet</h3>
        <p>Mark your best achievements as favorites to see them in your brag document. Use the ★ button on achievements to add them to your favorites.</p>
        <div class="empty-state-actions">
          <%= link_to "View All Achievements", achievements_path, class: "btn btn-primary" %>
          <%= link_to "Add New Achievement", new_achievement_path, class: "btn btn-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
