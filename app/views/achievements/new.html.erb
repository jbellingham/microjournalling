<%= turbo_frame_tag "achievement_form" do %>
  <div class="form-container" data-controller="brag-prompts">
    <h2>Add New Achievement</h2>
    
    <%= form_with model: @achievement, local: false, data: { turbo_frame: "_top" } do |form| %>
      <% if @achievement.errors.any? %>
        <div class="error-messages">
          <h4><%= pluralize(@achievement.errors.count, "error") %> prohibited this achievement from being saved:</h4>
          <ul>
            <% @achievement.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= form.label :title, class: "form-label" %>
        <%= form.text_field :title, class: "form-control", placeholder: "e.g., Led cross-team project to improve system performance", 
            data: { "brag-prompts-target": "title" } %>
      </div>

      <div class="form-group">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, class: "form-control", rows: 4, placeholder: "Describe your achievement in detail...", 
            data: { "brag-prompts-target": "description" } %>
      </div>

      <div class="form-group">
        <%= form.label :date, class: "form-label" %>
        <%= form.date_field :date, class: "form-control", value: Date.current %>
      </div>

      <div class="form-group">
        <%= form.label :category, class: "form-label" %>
        <%= form.select :category, 
            options_for_select(Achievement.category_options, @achievement.category), 
            { prompt: 'Select a category...' }, 
            { class: "form-control", data: { "brag-prompts-target": "category", action: "change->brag-prompts#categoryChanged" } } %>
        <small class="form-text text-muted" id="category-description">
          Choose the category that best describes this achievement. All categories capture details for promotion materials.
        </small>
      </div>

      <div class="brag-doc-fields" id="brag-doc-fields">
        <h3 class="section-title">Additional Details for Promotion Materials</h3>
        <p class="section-subtitle">These fields help you capture the impact and context needed for performance reviews and promotion discussions.</p>
        
        <div class="form-group">
          <%= form.label :impact_metrics, class: "form-label" %>
          <%= form.text_area :impact_metrics, class: "form-control", rows: 3, 
              placeholder: "Quantify the impact: saved $X, improved performance by Y%, used by Z users daily, etc.",
              data: { "brag-prompts-target": "impactMetrics" } %>
          <small class="form-text text-muted">Numbers and metrics that demonstrate the value of your work</small>
        </div>

        <div class="form-group">
          <%= form.label :collaboration_details, class: "form-label" %>
          <%= form.text_area :collaboration_details, class: "form-control", rows: 3, 
              placeholder: "Who did you work with? How did you mentor others? What cross-team collaboration occurred?",
              data: { "brag-prompts-target": "collaborationDetails" } %>
          <small class="form-text text-muted">Highlight mentorship, teamwork, and helping others</small>
        </div>

        <div class="form-group">
          <%= form.label :learning_outcomes, class: "form-label" %>
          <%= form.text_area :learning_outcomes, class: "form-control", rows: 3, 
              placeholder: "What new skills did you acquire? What technologies or processes did you learn?",
              data: { "brag-prompts-target": "learningOutcomes" } %>
          <small class="form-text text-muted">Document your professional growth and skill development</small>
        </div>

        <div class="form-group">
          <%= form.label :goals_supported, class: "form-label" %>
          <%= form.text_area :goals_supported, class: "form-control", rows: 2, 
              placeholder: "How does this achievement align with company or team goals?",
              data: { "brag-prompts-target": "goalsSupported" } %>
          <small class="form-text text-muted">Connect your work to broader organizational objectives</small>
        </div>
      </div>

      <div class="form-actions">
        <%= form.submit "Save Achievement", class: "btn btn-primary" %>
        <%= link_to "Cancel", achievements_path, class: "btn btn-secondary", data: { turbo_frame: "_top" } %>
      </div>
    <% end %>
  </div>
<% end %>
